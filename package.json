{
  "name": "promptkit",
  "version": "0.1.0",
  "description": "AI Prompt Workspace — clean, optimize, translate, and manage prompts for every AI model.",
  "author": "PromptKit",
  "private": true,
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "next dev",
    "dev:desktop": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "next build",
    "build:desktop": "next build && electron-builder --win portable",
    "start": "next start",
    "electron": "electron .",
    "lint": "eslint"
  },
  "build": {
    "appId": "com.promptkit.app",
    "productName": "PromptKit",
    "directories": {
      "output": "release"
    },
    "files": [
      ".next/**/*",
      "prisma/**/*",
      "public/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "prisma.config.ts",
      "next.config.*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      { "from": "prisma/dev.db", "to": "prisma/dev.db" }
    ],
    "win": {
      "target": ["portable"],
      "icon": "electron/icon.png"
    },
    "portable": {
      "artifactName": "PromptKit.exe"
    }
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.17",
    "@base-ui/react": "^1.6.0",
    "@better-auth/prisma-adapter": "^1.6.23",
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@stripe/stripe-js": "^9.12.0",
    "ai": "^7.0.34",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^1.25.0",
    "next": "16.2.11",
    "next-themes": "^0.4.6",
    "prisma": "^7.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.1.0"
  }
}
